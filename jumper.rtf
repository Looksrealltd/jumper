<script>\
  /* \uc0\u9472 \u9472  NAV ACTIVE STATE \u9472 \u9472  */\
  const sections = document.querySelectorAll('section[id]');\
  const navLinks = document.querySelectorAll('.nav-link');\
  const progressFill = document.getElementById('progress');\
\
  function updateNav() \{\
    const scrollY = window.scrollY;\
    const docH = document.body.scrollHeight - window.innerHeight;\
    progressFill.style.width = (scrollY / docH * 100).toFixed(1) + '%';\
\
    let current = '';\
    sections.forEach(s => \{\
      if (scrollY >= s.offsetTop - 120) current = s.id;\
    \});\
    navLinks.forEach(l => \{\
      l.classList.toggle('active', l.getAttribute('href') === '#' + current);\
    \});\
  \}\
  window.addEventListener('scroll', updateNav, \{ passive: true \});\
  updateNav();\
\
  /* \uc0\u9472 \u9472  WEEK ACCORDION \u9472 \u9472  */\
  function toggleWeek(header) \{\
    const body = header.nextElementSibling;\
    const isOpen = header.classList.contains('open');\
    header.classList.toggle('open', !isOpen);\
    body.classList.toggle('open', !isOpen);\
  \}\
\
  /* \uc0\u9472 \u9472  DAY ACCORDION \u9472 \u9472  */\
  function toggleDay(row) \{\
    const detail = row.querySelector('.day-detail');\
    const isOpen = row.classList.contains('open');\
    row.classList.toggle('open', !isOpen);\
    if (detail) detail.classList.toggle('open', !isOpen);\
  \}\
\
  /* \uc0\u9472 \u9472  NAV SMOOTH SCROLL \u9472 \u9472  */\
  navLinks.forEach(l => \{\
    l.addEventListener('click', e => \{\
      e.preventDefault();\
      const target = document.querySelector(l.getAttribute('href'));\
      if (target) target.scrollIntoView(\{ behavior: 'smooth', block: 'start' \});\
    \});\
  \});\
</script>\
